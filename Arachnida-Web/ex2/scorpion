# =============================================================================
# EXIF parser (pure stdlib — no external dependencies)
# =============================================================================

def _read_uint16(data, offset, big_endian):
    fmt = ">H" if big_endian else "<H"
    return struct.unpack_from(fmt, data, offset)[0]


def _read_uint32(data, offset, big_endian):
    fmt = ">I" if big_endian else "<I"
    return struct.unpack_from(fmt, data, offset)[0]


def _read_int32(data, offset, big_endian):
    fmt = ">i" if big_endian else "<i"
    return struct.unpack_from(fmt, data, offset)[0]


def _rational(data, offset, big_endian):
    num = _read_uint32(data, offset, big_endian)
    den = _read_uint32(data, offset + 4, big_endian)
    if den == 0:
        return f"{num}/0"
    if num % den == 0:
        return num // den
    return f"{num}/{den}"


def _srational(data, offset, big_endian):
    num = _read_int32(data, offset, big_endian)
    den = _read_int32(data, offset + 4, big_endian)
    if den == 0:
        return f"{num}/0"
    return f"{num}/{den}"


_TYPE_SIZE = {1: 1, 2: 1, 3: 2, 4: 4, 5: 8, 6: 1, 7: 1, 8: 2, 9: 4, 10: 8, 11: 4, 12: 8}


def _decode_value(data, type_id, count, value_offset, big_endian):
    size = _TYPE_SIZE.get(type_id, 1)
    total = size * count

    if total <= 4:
        raw_offset = value_offset
    else:
        raw_offset = _read_uint32(data, value_offset, big_endian)

    if raw_offset + total > len(data):
        return None

    if type_id == 2:  # ASCII
        raw = data[raw_offset: raw_offset + count]
        return raw.rstrip(b"\x00").decode("latin-1", errors="replace")
    elif type_id == 3:  # SHORT
        vals = [_read_uint16(data, raw_offset + i * 2, big_endian) for i in range(count)]
        return vals[0] if count == 1 else vals
    elif type_id == 4:  # LONG
        vals = [_read_uint32(data, raw_offset + i * 4, big_endian) for i in range(count)]
        return vals[0] if count == 1 else vals
    elif type_id == 5:  # RATIONAL
        vals = [_rational(data, raw_offset + i * 8, big_endian) for i in range(count)]
        return vals[0] if count == 1 else vals
    elif type_id == 10:  # SRATIONAL
        vals = [_srational(data, raw_offset + i * 8, big_endian) for i in range(count)]
        return vals[0] if count == 1 else vals
    elif type_id == 7:  # UNDEFINED
        raw = data[raw_offset: raw_offset + count]
        try:
            return raw.decode("ascii", errors="replace")
        except Exception:
            return repr(raw[:20])
    elif type_id == 1:  # BYTE
        vals = list(data[raw_offset: raw_offset + count])
        return vals[0] if count == 1 else vals
    else:
        return None


def _parse_ifd(data, ifd_offset, big_endian, tags_dict):
    """Parse one IFD and return {tag_name: value}."""
    result = {}
    if ifd_offset + 2 > len(data):
        return result
    count = _read_uint16(data, ifd_offset, big_endian)
    offset = ifd_offset + 2

    for _ in range(count):
        if offset + 12 > len(data):
            break
        tag_id = _read_uint16(data, offset, big_endian)
        type_id = _read_uint16(data, offset + 2, big_endian)
        value_count = _read_uint32(data, offset + 4, big_endian)
        value_offset_field = offset + 8

        value = _decode_value(data, type_id, value_count, value_offset_field, big_endian)

        tag_name = tags_dict.get(tag_id, f"Tag_0x{tag_id:04X}")
        if value is not None:
            result[tag_name] = value

        offset += 12

    return result


def parse_exif_from_jpeg(data: bytes) -> dict:
    """
    Extract EXIF data from raw JPEG bytes.
    Returns a dict of {tag_name: value}.
    """
    # Find APP1 marker (0xFFE1)
    i = 0
    while i < len(data) - 1:
        if data[i] == 0xFF:
            marker = data[i + 1]
            if marker == 0xE1:  # APP1
                length = struct.unpack_from(">H", data, i + 2)[0]
                segment = data[i + 4: i + 2 + length]
                if segment[:6] == b"Exif\x00\x00":
                    return _parse_exif_segment(segment[6:])
                # else might be XMP — skip
            elif marker in (0xD8, 0xD9, 0xDA):
                pass
            else:
                if i + 3 < len(data):
                    length = struct.unpack_from(">H", data, i + 2)[0]
                    i += 2 + length
                    continue
        i += 1
    return {}


def _parse_exif_segment(exif_data: bytes) -> dict:
    """Parse the EXIF segment (after the 'Exif\\x00\\x00' header)."""
    if len(exif_data) < 8:
        return {}

    # Byte order
    bom = exif_data[:2]
    if bom == b"II":
        big_endian = False
    elif bom == b"MM":
        big_endian = True
    else:
        return {}

    # IFD0 offset
    ifd0_offset = _read_uint32(exif_data, 4, big_endian)
    tags = _parse_ifd(exif_data, ifd0_offset, big_endian, EXIF_TAGS)

    # Sub-IFDs
    for sub_key, sub_tags in (("ExifIFDPointer", EXIF_TAGS), ("GPSInfoIFDPointer", EXIF_TAGS)):
        if sub_key in tags:
            sub_offset = tags.pop(sub_key)
            if isinstance(sub_offset, int):
                sub = _parse_ifd(exif_data, sub_offset, big_endian, EXIF_TAGS)
                tags.update(sub)

    return tags


def parse_exif_from_png(data: bytes) -> dict:
    """Extract text metadata from PNG tEXt/iTXt/zTXt chunks."""
    meta = {}
    if data[:8] != b"\x89PNG\r\n\x1a\n":
        return meta
    i = 8
    while i + 12 <= len(data):
        length = struct.unpack_from(">I", data, i)[0]
        chunk_type = data[i + 4: i + 8].decode("ascii", errors="replace")
        chunk_data = data[i + 8: i + 8 + length]

        if chunk_type == "tEXt":
            parts = chunk_data.split(b"\x00", 1)
            if len(parts) == 2:
                key = parts[0].decode("latin-1", errors="replace")
                val = parts[1].decode("latin-1", errors="replace")
                meta[key] = val
        elif chunk_type == "iTXt":
            # keyword\x00compression_flag\x00compression_method\x00lang\x00translated_keyword\x00text
            parts = chunk_data.split(b"\x00", 5)
            if len(parts) >= 6:
                key = parts[0].decode("utf-8", errors="replace")
                val = parts[5].decode("utf-8", errors="replace")
                meta[key] = val

        i += 12 + length
    return meta


# =============================================================================
# File attribute helpers
# =============================================================================

def _file_attributes(path: str) -> dict:
    stat = os.stat(path)
    attrs = {}
    attrs["File Size"] = f"{stat.st_size} bytes"
    # Creation time (best effort — ctime on Linux is inode change, not true creation)
    try:
        ctime = datetime.datetime.fromtimestamp(stat.st_birthtime)
        attrs["Creation Date"] = ctime.isoformat(sep=" ", timespec="seconds")
    except AttributeError:
        pass
    mtime = datetime.datetime.fromtimestamp(stat.st_mtime)
    attrs["Modification Date"] = mtime.isoformat(sep=" ", timespec="seconds")
    return attrs


def _image_dimensions(path: str, ext: str):
    """Return (width, height) by reading minimal header bytes."""
    try:
        with open(path, "rb") as f:
            data = f.read(26)
        if ext in (".jpg", ".jpeg"):
            # Parse SOF markers for dimensions
            with open(path, "rb") as f:
                raw = f.read(65536)
            i = 2  # skip SOI
            while i < len(raw) - 1:
                if raw[i] != 0xFF:
                    break
                marker = raw[i + 1]
                if marker in (0xC0, 0xC2):  # SOF0, SOF2
                    h = struct.unpack_from(">H", raw, i + 5)[0]
                    w = struct.unpack_from(">H", raw, i + 7)[0]
                    return w, h
                length = struct.unpack_from(">H", raw, i + 2)[0]
                i += 2 + length
        elif ext == ".png":
            w = struct.unpack_from(">I", data, 16)[0]
            h = struct.unpack_from(">I", data, 20)[0]
            return w, h
        elif ext == ".gif":
            w = struct.unpack_from("<H", data, 6)[0]
            h = struct.unpack_from("<H", data, 8)[0]
            return w, h
        elif ext == ".bmp":
            w = struct.unpack_from("<i", data, 18)[0]
            h = abs(struct.unpack_from("<i", data, 22)[0])
            return w, h
    except Exception:
        pass
    return None, None


# =============================================================================
# Main display logic
# =============================================================================

def display_metadata(path: str) -> None:
    ext = Path(path).suffix.lower()
    sep = "─" * 60

    print(f"\n{sep}")
    print(f"  File: {path}")
    print(sep)

    # Basic file attributes
    attrs = _file_attributes(path)
    for k, v in attrs.items():
        print(f"  {k:<28} {v}")

    # Image dimensions
    w, h = _image_dimensions(path, ext)
    if w and h:
        print(f"  {'Dimensions':<28} {w} x {h} px")

    # EXIF / embedded metadata
    print(f"\n  {'── EXIF / Metadata ──'}")
    exif = {}

    try:
        with open(path, "rb") as f:
            raw = f.read()
    except OSError as exc:
        print(f"  [ERROR] Cannot read file: {exc}")
        return

    if ext in (".jpg", ".jpeg"):
        exif = parse_exif_from_jpeg(raw)
    elif ext == ".png":
        exif = parse_exif_from_png(raw)
    else:
        exif = {}

    if exif:
        for tag, value in sorted(exif.items()):
            # Skip large or binary blobs
            val_str = str(value)
            if len(val_str) > 120:
                val_str = val_str[:117] + "..."
            print(f"  {tag:<28} {val_str}")
    else:
        print("  (no EXIF metadata found)")

    print(sep)


def main():
    if len(sys.argv) < 2:
        print("Usage: ./scorpion FILE1 [FILE2 ...]", file=sys.stderr)
        sys.exit(1)

    files = sys.argv[1:]
    errors = 0

    for filepath in files:
        ext = Path(filepath).suffix.lower()

        if not os.path.isfile(filepath):
            print(f"scorpion: {filepath!r}: no such file", file=sys.stderr)
            errors += 1
            continue

        if ext not in SUPPORTED_EXTENSIONS:
            print(
                f"scorpion: {filepath!r}: unsupported extension {ext!r} "
                f"(supported: {', '.join(sorted(SUPPORTED_EXTENSIONS))})",
                file=sys.stderr,
            )
            errors += 1
            continue

        display_metadata(filepath)

    sys.exit(1 if errors and len(files) == errors else 0)


if __name__ == "__main__":
    main()
