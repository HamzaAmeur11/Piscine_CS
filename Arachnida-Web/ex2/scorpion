#!/usr/bin/env python3
"""
scorpion - Image metadata viewer for the 42 Arachnida project.

Usage: ./scorpion FILE1 [FILE2 ...]

Displays file attributes and EXIF metadata for each image.
Supports: .jpg/.jpeg, .png, .gif, .bmp
"""

import sys
import os
import struct
import datetime
from pathlib import Path

# Supported extensions (same as spider)
